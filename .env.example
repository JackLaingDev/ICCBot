# =========================================
# ENVIRONMENT
# =========================================

# Mode: development | demo | live
ENVIRONMENT=development

# =========================================
# MT5 SETTINGS
# =========================================

# Leave blank if using local logged-in terminal
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Path to MetaTrader 5 terminal (optional)
MT5_PATH=

# =========================================
# TRADING SETTINGS (V1 - FIXED)
# =========================================

SYMBOL=EURUSD
TIMEFRAME=M15

# Risk per trade (percentage of equity)
RISK_PER_TRADE=0.5

# Max allowed spread (points or pips depending on implementation)
MAX_SPREAD=20

# Max number of open trades
MAX_OPEN_TRADES=1

# Max daily loss (percentage)
MAX_DAILY_LOSS=2.0

# =========================================
# STRATEGY SETTINGS (ICC BASELINE)
# =========================================

# Strategy selector: icc | velocity
STRATEGY_NAME=icc

EMA_PERIOD=200

# Take profit multiplier (RR)
TAKE_PROFIT_RR=1.5

# Stop loss type: atr | structure
STOP_LOSS_TYPE=atr

# ATR multiplier (if using ATR stop)
ATR_MULTIPLIER=1.5

# =========================================
# VELOCITY STRATEGY SETTINGS
# =========================================

# Velocity definition: ln(close_t / close_{t-k}) / ATR_t
VELOCITY_LOOKBACK_K=4
VELOCITY_ATR_PERIOD=14

# If <= 1, raw velocity is used (no smoothing)
VELOCITY_SMOOTHING_SPAN=1

# Entry and persistence
VELOCITY_ENTRY_THRESHOLD=0.75
VELOCITY_ENTRY_PERSISTENCE_BARS=2

# Exit on velocity drawdown from in-trade peak/trough
VELOCITY_EXIT_DRAWDOWN_FRACTION=0.35

# Disaster stop in ATR units
VELOCITY_ATR_STOP_MULTIPLIER=2.0

# Bars to wait after an exit before re-entry
VELOCITY_COOLDOWN_BARS=0

# Optional trend filter
VELOCITY_USE_EMA_TREND_FILTER=false
VELOCITY_TREND_EMA_PERIOD=200

# =========================================
# DATA SETTINGS
# =========================================

# Number of candles to fetch
LOOKBACK_BARS=5000

# =========================================
# LOGGING
# =========================================

LOG_LEVEL=INFO

# Save logs to file (true/false)
LOG_TO_FILE=true

# =========================================
# RUNTIME
# =========================================

# Seconds between checks (used for polling loop)
POLL_INTERVAL=60

# =========================================
# FUTURE / OPTIONAL
# =========================================

# Telegram alerts (optional later)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Database path (if using SQLite/DuckDB later)
DATABASE_PATH=./data/trading.db